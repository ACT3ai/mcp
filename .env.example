# ACT3 MCP server configuration (all optional; sensible defaults are built in).
# Copy to .env only for local development — end users normally run `act3-mcp login`.

# Base URL of the ACT3 backend API.
#   Production (default): https://api.act3ai.com
#   Local dev:            http://localhost:3080
ACT3_API_URL=https://api.act3ai.com

# API key. Prefer `act3-mcp login` (stores it in ~/.act3/credentials.json).
# Setting this env var overrides the stored credentials — useful for CI.
# ACT3_API_KEY=

# Override where credentials are stored (default: ~/.act3/credentials.json).
# ACT3_CONFIG_DIR=~/.act3

# Log level: error | warn | info | debug (default: info). Logs go to stderr.
# ACT3_LOG_LEVEL=info
